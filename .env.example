PORT=3012
NODE_ENV=development
LOG_LEVEL=info

# DPSS upstream settings
DPSS_ALLOWED_ENVIRONMENTS=itrontotal.com,itrontotal.ca,stage-ca.itronapps.com,itrontotalstage.com,itroneyva.eu,itroneyva.com.au
# Configurable mapping used by the Region dropdown and API environment resolution.
# Format: Region:environment,Region:environment
REGION_ENVIRONMENT_MAP=USA:itrontotal.com,Canada:itrontotal.ca,Europe:itroneyva.eu,Australia:itroneyva.com.au
# Regional Key Vault secret URI mappings for credential resolution by environment.
# When a region is selected, the app fetches credentials from the region's Key Vault instance.
# Format: environment:clientIdUri,clientSecretUri|environment:clientIdUri,clientSecretUri
# Default mapping (if not set):
#   itrontotal.com -> kv-usw-dpss1-prod/DPSSSubscriberClientId, kv-usw-dpss1-prod/DPSSSubscriberClientSecret
#   itrontotal.ca -> kv-cac-dpss1-prod/DPSSSubscriberClientId, kv-cac-dpss1-prod/DPSSSubscriberClientSecret
#   itroneyva.eu -> kv-eun-dpss1-prod/DPSSSubscriberClientId, kv-eun-dpss1-prod/DPSSSubscriberClientSecret
#   itroneyva.com.au -> kv-aue-dpss1-prod/DPSSSubscriberClientId, kv-aue-dpss1-prod/DPSSSubscriberClientSecret
REGIONAL_KEY_VAULT_SECRETS_BY_ENVIRONMENT=
# Legacy service account credentials (fallback when regional credentials are not available)
DPSS_SERVICE_CLIENT_ID=
DPSS_SERVICE_CLIENT_ID_KEY_VAULT_URI=
DPSS_SERVICE_CLIENT_SECRET=
DPSS_SERVICE_CLIENT_SECRET_KEY_VAULT_URI=
# US-specific data products credentials (optional, used when region=USA)
DPSS_US_DATA_PRODUCTS_CLIENT_ID=
DPSS_US_DATA_PRODUCTS_CLIENT_ID_KEY_VAULT_URI=
DPSS_US_DATA_PRODUCTS_CLIENT_SECRET=
DPSS_US_DATA_PRODUCTS_CLIENT_SECRET_KEY_VAULT_URI=
DPSS_US_DATA_PRODUCTS_SCOPE=DPSSSubscriberApi
# If true and Key Vault lookup fails, app may use non-empty DPSS_* plaintext values.
# Default: true in development, false in production.
KEY_VAULT_ALLOW_ENV_FALLBACK=true
UPSTREAM_TIMEOUT_MS=15000

# reCAPTCHA v3
# Leave both blank during local development — bypass mode activates automatically.
# In production both are required: get them at https://www.google.com/recaptcha/admin/create
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
RECAPTCHA_MIN_SCORE=0.5

# PostgreSQL
# Use localhost when running npm run dev directly on your machine.
# Docker Compose overrides this automatically to use the 'db' service hostname.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dpss_subscriber_requests

# JWT for local admin auth
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=8h
# Admin bootstrap is disabled by default.
# Enable only for one-time setup, then disable again.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_TOKEN=

# SMTP
# Toggle email target:
# SMTP_MODE=real  -> uses SMTP_HOST/SMTP_PORT/SMTP_SECURE/SMTP_USER/SMTP_PASS
# SMTP_MODE=local -> uses LOCAL_SMTP_HOST/LOCAL_SMTP_PORT and disables auth/TLS
SMTP_MODE=real
SMTP_HOST=mx0b-00268a01.pphosted.com
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
LOCAL_SMTP_HOST=localhost
LOCAL_SMTP_PORT=1025
SMTP_FROM=no-reply@itrontotal.com
ALERT_EMAILS=ops@example.com,team@example.com

# CORS
# Do not leave empty in production.
ALLOWED_ORIGINS=http://localhost:3012
